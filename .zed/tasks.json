[
    {
        "label": "run",
        "command": "if [[ \"$ZED_FILE\" == *\"/examples/\"* ]]; then cargo test --example \"$ZED_STEM\"; elif [[ \"$ZED_FILE\" == *\"/tests/\"* ]]; then cargo test --test \"$ZED_STEM\"; elif [[ \"$ZED_STEM\" == \"lib\" ]]; then cargo test --lib; elif [[ \"$ZED_STEM\" == \"main\" ]]; then cargo test --bins; else cargo test \"$ZED_STEM\"; fi",
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
        "tags": ["rust", "test"],
        // "env": { "LOGURU_LEVEL": "DEBUG" },
        "reveal": "always",
        "hide": "never",
        "shell": "system",
        "show_summary": false,
        "show_command": false,
    },
