{
    "$schema": "https://opencode.ai/config.json",
    "compaction": {
      "auto": true
    },
    "permission": {
        "external_directory": {
          "~/.cargo/registry/**": "allow",
          "~/.cargo/git/**": "allow"
        },
        "bash": {
            "git *": "allow",
            "git commit *": "deny",
            "git push *": "deny",
            "grep *": "allow",
            "cargo build*": "allow",
            "cargo clippy*": "allow",
            "cargo fmt*": "allow",
            "cargo test *": "allow",
            "cargo nextest run*": "allow"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "agent": {
        "build": {
            "permission": {
                "bash": {
                    "*": "ask",
                    "rm *": "ask",
                    "git *": "allow",
                    "git commit *": "ask",
                    "git push *": "deny",
                    "grep *": "allow",
                    "cargo build*": "allow",
                    "cargo clippy*": "allow",
                    "cargo fmt*": "allow",
                    "cargo test *": "allow",
                    "cargo nextest run*": "allow"
                }
            }
        }
    },
    "provider": {
        "opencode": {
            "models": {
                "opencode/big-pickle": {
                    "name": "Big Pickle",
                    "limit": {
                        "context": 180000,
                        "output": 16000
                    }
                }
            }
        }
    }
}
